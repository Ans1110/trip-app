# Build context is services/api/ — paths are relative to that.

# Git
.git
.gitignore

# Env & logs
*.env
*.log
logs/

# Build output
coverage.out
*.test
tmp/

# IDE
.vscode/
.claude/

# Secrets baked at runtime via volume mount — never copy into image
keys/

# Local config overrides
config/*.local.yml
config/*.dev.yml
