# Server
APP_ENV=development
APP_PORT=8080
CONFIG_PATH=./config/config.yaml
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=tripapp_db
DB_SSLMODE=disable

DB_URL=postgres://postgres:postgres@localhost:5432/tripapp_db?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_PRIVATE_KEY_PATH=./keys/private_key.pem
JWT_PUBLIC_KEY_PATH=./keys/public_key.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./keys/apple_private_key.p8
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tripapp
MINIO_USE_SSL=false

# AI
OPENAI_API_KEY=
GEMINI_API_KEY=

# Maps / Location
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=test@tripapp.com

# BFF
BACKEND_URL=http://localhost:8080
NEXTAUTH_SECRET=MIjIqBAFhQlQQGcCLLldgJ5KyHXDxY73/flipNX4yzk=
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
